# ==============================================
# FlexHunter - Environment Configuration
# ==============================================

# Shopify App
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_analytics,read_inventory
SHOPIFY_APP_URL=https://your-tunnel.ngrok.io
SHOPIFY_AUTH_CALLBACK_PATH=/api/auth/callback

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/flexhunter?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# AI / LLM
OPENAI_API_KEY=your_openai_api_key
AI_MODEL=gpt-4o
AI_SCORING_MODEL=gpt-4o-mini

# App Config
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-this-to-random-string

# Provider Keys (future)
ALIEXPRESS_API_KEY=
CJ_API_KEY=

# S3 (future)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
